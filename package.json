{
  "name": "cc-ding",
  "version": "0.0.5",
  "description": "钉钉机器人对接本地Claude工具",
  "keywords": [
    "cli",
    "claude",
    "ding"
  ],
  "main": "dist/index",
  "dependencies": {
    "commander": "^7.2.0",
    "dotenv": "^16.6.1",
    "shelljs": "^0.10.0",
    "urllib": "^4.9.0",
    "utils-ok": "^1.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^9.1.1",
    "@types/node": "^16.18.126",
    "@types/shelljs": "^0.10.0",
    "blacklint": "^1.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "eslint-config-egg": "^14.1.0",
    "globals": "^17.6.0",
    "husky": "^8.0.3",
    "javascript-obfuscator": "^5.4.2",
    "mocha": "^8.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "author": "yhn",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "cc-ding": "./dist/bin/cc-ding.js"
  },
  "scripts": {
    "lint": "eslint . && tsc && npm run blacklint",
    "lint:fix": "eslint . --fix",
    "blacklint": "utils-ok blacklint -bd 'src bin'",
    "test": "mocha 'test/**/*.test.ts'",
    "build": "npm run lint && sh build.sh",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  }
}
